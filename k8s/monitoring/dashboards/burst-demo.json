      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count(kube_node_labels{label_node_type=\"burst\"}) or vector(0)",
          "legendFormat": "EKS Burst Nodes",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
